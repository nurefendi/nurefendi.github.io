---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const published = posts
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Blog — Nur Efendi" description="Articles and writings about technology, web development, and career.">
  <section class="section">
    <div class="container">
      <h1 class="page-title">Blog</h1>
      <p class="page-subtitle">Articles, tutorials, and notes about technology and web development.</p>

      {
        published.length > 0 ? (
          <div class="blog-list">
            {published.map((post) => (
              <article class="blog-card">
                <time datetime={post.data.date.toISOString()} class="blog-date">
                  {new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric' }).format(post.data.date)}
                </time>
                <h2><a href={`/blog/${post.id}`}>{post.data.title}</a></h2>
                <p>{post.data.description}</p>
                <div class="blog-tags">
                  {post.data.tags?.map((tag) => <span class="tag">{tag}</span>)}
                </div>
              </article>
            ))}
          </div>
        ) : (
          <p class="empty-state">No posts yet. Stay tuned!</p>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  .page-title {
    font-size: 2.2rem;
    margin: 0 0 0.25rem;
    font-weight: 700;
  }

  .page-subtitle {
    color: var(--muted);
    margin: 0 0 2.5rem;
    font-size: 1rem;
  }

  .blog-list {
    display: grid;
    gap: 2rem;
  }

  .blog-card h2 {
    margin: 0.3rem 0 0.5rem;
    font-size: 1.2rem;
  }

  .blog-card h2 a {
    color: var(--text);
  }

  .blog-card h2 a:hover {
    opacity: 0.6;
  }

  .blog-card p {
    margin: 0 0 0.75rem;
    color: var(--muted);
    line-height: 1.65;
  }

  .blog-date {
    font-size: 0.85rem;
    color: var(--muted);
  }

  .blog-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    font-size: 0.8rem;
    color: var(--muted);
    border: 1px solid var(--border);
    padding: 0.15rem 0.6rem;
    border-radius: var(--radius);
  }

  .empty-state {
    color: var(--muted);
    text-align: center;
    padding: 4rem 0;
  }
</style>
