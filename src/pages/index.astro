---
import BaseLayout from '../layouts/BaseLayout.astro';
import GitHubContributions from '../components/GitHubContributions.astro';
---

<BaseLayout title="Nurefendi — Pengembang Web & Penulis">
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-card">
        <div class="hero-text">
          <p class="eyebrow">Selamat Datang</p>
          <h1>Nurefendi</h1>
          <p class="lead">Pengembang Web & Penulis. Membangun hal-hal bermanfaat dan berbagi cerita tentang teknologi, karier, dan kehidupan.</p>
          <div class="hero-actions">
            <a class="button button-primary" href="#contact">Hubungi Saya</a>
            <a class="button button-secondary" href="/blog">Baca Blog</a>
          </div>
        </div>
        <aside class="hero-panel">
          <div class="hero-panel-content">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            <p>Tersedia untuk kolaborasi proyek dan diskusi teknologi.</p>
          </div>
          <div class="hero-stats">
            <div class="hero-stat">
              <strong>Web</strong>
              Pengembangan web modern
            </div>
            <div class="hero-stat">
              <strong>Blog</strong>
              Artikel & tutorial
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Tentang -->
  <section class="section" id="tentang">
    <div class="container">
      <div class="about-card">
        <h2>Tentang Saya</h2>
        <p>
          Saya adalah pengembang web yang fokus membangun aplikasi yang bersih, cepat, dan mudah digunakan.
          Selain coding, saya juga menulis tentang pengalaman, teknologi, dan hal-hal lain yang saya temui
          dalam perjalanan karier.
        </p>
        <p>
          Situs ini adalah rumah digital saya — tempat saya menampilkan karya, berbagi pemikiran lewat blog,
          dan terhubung dengan orang-orang menarik.
        </p>
      </div>
    </div>
  </section>

  <!-- Keahlian -->
  <section class="section" id="keahlian">
    <div class="container">
      <h2 class="section-title">Keahlian</h2>
      <p class="section-subtitle">Teknologi dan tools yang saya gunakan.</p>
      <div class="grid-3">
        <article class="card">
          <h3>Frontend</h3>
          <p>HTML, CSS, JavaScript, React, Astro, Tailwind CSS — membangun antarmuka yang responsif dan modern.</p>
        </article>
        <article class="card">
          <h3>Backend</h3>
          <p>Node.js, Express, API REST, database SQL & NoSQL — merancang sistem yang andal di sisi server.</p>
        </article>
        <article class="card">
          <h3>Lainnya</h3>
          <p>Git, Linux, Docker, Figma — tools pendukung untuk workflow yang efisien dan kolaboratif.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- Pengalaman -->
  <section class="section" id="pengalaman">
    <div class="container">
      <h2 class="section-title">Pengalaman</h2>
      <p class="section-subtitle">Perjalanan karier dan organisasi.</p>
      <div class="timeline">
        <div class="timeline-item card">
          <div class="timeline-meta">
            <span class="tag">2024 — Sekarang</span>
            <span class="timeline-role">Pengembang Web</span>
          </div>
          <h3>Freelance</h3>
          <p>Membangun dan mengelola situs web untuk berbagai klien. Fokus pada performa, aksesibilitas, dan pengalaman pengguna.</p>
        </div>
        <div class="timeline-item card">
          <div class="timeline-meta">
            <span class="tag">2023 — 2024</span>
            <span class="timeline-role">Junior Developer</span>
          </div>
          <h3>Startup Teknologi</h3>
          <p>Bergabung dalam tim pengembangan produk. Bertanggung jawab atas fitur frontend dan integrasi API.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Proyek -->
  <section class="section" id="proyek">
    <div class="container">
      <h2 class="section-title">Proyek</h2>
      <p class="section-subtitle">Beberapa karya yang pernah dibuat.</p>
      <div class="grid-2">
        <article class="card project-card">
          <div class="project-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          </div>
          <h3>Nama Proyek</h3>
          <p>Deskripsi singkat tentang proyek ini dan teknologi yang digunakan.</p>
          <a href="#" class="button button-secondary" style="margin-top:1rem;display:inline-flex">Lihat Detail</a>
        </article>
        <article class="card project-card">
          <div class="project-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          </div>
          <h3>Nama Proyek</h3>
          <p>Deskripsi singkat tentang proyek ini dan teknologi yang digunakan.</p>
          <a href="#" class="button button-secondary" style="margin-top:1rem;display:inline-flex">Lihat Detail</a>
        </article>
      </div>
    </div>
  </section>

  <!-- Kontribusi GitHub -->
  <section class="section" id="kontribusi">
    <div class="container">
      <h2 class="section-title">Aktivitas GitHub</h2>
      <p class="section-subtitle">Grafik kontribusi dalam 1 tahun terakhir.</p>
      <GitHubContributions />
    </div>
  </section>

  <!-- Kontak -->
  <section class="section" id="contact">
    <div class="container">
      <div class="contact-card card">
        <h2>Hubungi Saya</h2>
        <p>Jika Anda tertarik untuk berkolaborasi, diskusi, atau sekadar menyapa — silakan hubungi saya melalui salah satu saluran di bawah.</p>
        <div class="contact-links">
          <a href="https://github.com/nurefendi" target="_blank" rel="noopener" class="button button-secondary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            GitHub
          </a>
          <a href="mailto:nur.efendi2505@gmail.com" class="button button-secondary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            Email
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    min-height: 80vh;
    display: flex;
    align-items: center;
    padding: 2rem 0 4rem;
  }

  .hero-card {
    width: 100%;
    background: var(--surface);
    border-radius: 28px;
    padding: 4rem;
    box-shadow: var(--shadow);
    display: grid;
    gap: 2.5rem;
    grid-template-columns: 1.2fr 1fr;
    align-items: center;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.6rem, 6vw, 4.8rem);
    line-height: 1.05;
  }

  .lead {
    margin: 1.25rem 0 0;
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--muted);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2rem;
  }

  .hero-panel {
    background: linear-gradient(180deg, #1e3a8a 0%, #1d4ed8 100%);
    color: #fff;
    border-radius: var(--radius);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .hero-panel-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .hero-panel-content p {
    margin: 0;
    line-height: 1.6;
    opacity: 0.9;
  }

  .hero-stats {
    display: grid;
    gap: 0.75rem;
  }

  .hero-stat {
    padding: 1rem 1.25rem;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(6px);
    font-size: 0.9rem;
    line-height: 1.4;
  }

  .hero-stat strong {
    display: block;
    font-size: 1.4rem;
    margin-bottom: 0.2rem;
  }

  .about-card {
    background: var(--surface);
    border-radius: var(--radius);
    padding: 2.5rem;
    box-shadow: var(--shadow-sm);
    max-width: 740px;
  }

  .about-card h2 {
    margin: 0 0 1rem;
    font-size: 1.6rem;
  }

  .about-card p {
    margin: 0 0 1rem;
    color: var(--muted);
    line-height: 1.7;
  }

  .about-card p:last-child {
    margin-bottom: 0;
  }

  .timeline {
    display: grid;
    gap: 1.25rem;
  }

  .timeline-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }

  .timeline-role {
    font-size: 0.85rem;
    color: var(--muted);
  }

  .timeline-item h3 {
    margin: 0 0 0.5rem;
  }

  .project-card .project-icon {
    width: 48px;
    height: 48px;
    border-radius: 14px;
    background: var(--primary-light);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--primary);
    margin-bottom: 1rem;
  }

  .contact-card {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
    padding: 3rem;
  }

  .contact-card h2 {
    margin: 0 0 0.75rem;
    font-size: 1.6rem;
  }

  .contact-card p {
    color: var(--muted);
    margin: 0 0 2rem;
  }

  .contact-links {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  @media (max-width: 860px) {
    .hero-card {
      grid-template-columns: 1fr;
      padding: 2rem;
    }

    .hero {
      min-height: auto;
      padding: 1rem 0 2rem;
    }

    .about-card {
      padding: 1.5rem;
    }

    .contact-card {
      padding: 2rem;
    }
  }
</style>
