---
import BaseLayout from '../layouts/BaseLayout.astro';
import GitHubContributions from '../components/GitHubContributions.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const published = posts
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Nur Efendi — Web Developer & Writer">
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <h1 class="hero-name">
        Nur Efendi
        <button class="theme-toggle" aria-label="Toggle theme">
          <svg class="sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
          <svg class="moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
      </h1>
      <p class="hero-bio">Web developer & writer. Building useful things and sharing stories about technology, career, and life.</p>
      <div class="hero-chart">
        <p class="chart-label">GitHub Activity &middot; last year</p>
        <GitHubContributions />
      </div>
      <div class="hero-social">
        <a href="https://www.linkedin.com/in/nurefendi/" target="_blank" rel="noopener" aria-label="LinkedIn">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href="https://github.com/nurefendi" target="_blank" rel="noopener" aria-label="GitHub">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        </a>
        <a href="mailto:nur.efendi2505@gmail.com" aria-label="Email">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 13.181l8-5.455v-1.726h-16v1.726l8 5.455zm0 2.819l-8-5.455v7.455h16v-7.455l-8 5.455z"/></svg>
        </a>
        <a href="https://www.instagram.com/_nurefendi/" target="_blank" rel="noopener" aria-label="Instagram">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Tabs -->
  <section class="section" id="content">
    <div class="container">
      <nav class="tabs">
        <button class="tab active" data-tab="projects">Projects</button>
        <button class="tab" data-tab="skills">Skills</button>
        <button class="tab" data-tab="blog">Blog</button>
      </nav>

      <!-- Projects -->
      <div class="tab-content active" id="tab-projects">
        <div class="grid-2">
          <article class="project-item">
            <h3>Project Name</h3>
            <p>Short description of the project and the technologies used.</p>
            <a href="#" class="project-link">View details &rarr;</a>
          </article>
          <article class="project-item">
            <h3>Project Name</h3>
            <p>Short description of the project and the technologies used.</p>
            <a href="#" class="project-link">View details &rarr;</a>
          </article>
        </div>
      </div>

      <!-- Skills -->
      <div class="tab-content" id="tab-skills">
        <div class="grid-3">
          <article class="skill-item">
            <h3>Frontend</h3>
            <p>HTML, CSS, JavaScript, React, Astro, Tailwind CSS &mdash; building responsive and modern interfaces.</p>
          </article>
          <article class="skill-item">
            <h3>Backend</h3>
            <p>Node.js, Express, REST API, SQL &amp; NoSQL databases &mdash; designing reliable server-side systems.</p>
          </article>
          <article class="skill-item">
            <h3>Tools</h3>
            <p>Git, Linux, Docker, Figma &mdash; supporting tools for efficient and collaborative workflows.</p>
          </article>
        </div>
      </div>

      <!-- Blog -->
      <div class="tab-content" id="tab-blog">
        {
          published.length > 0 ? (
            <div class="blog-list">
              {published.map((post) => (
                <article class="blog-item">
                  <time datetime={post.data.date.toISOString()}>
                    {new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric' }).format(post.data.date)}
                  </time>
                  <h3><a href={`/blog/${post.id}`}>{post.data.title}</a></h3>
                  <p>{post.data.description}</p>
                  {
                    post.data.tags?.length > 0 && (
                      <div class="blog-tags">
                        {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
                      </div>
                    )
                  }
                </article>
              ))}
            </div>
          ) : (
            <p class="empty">No posts yet. Stay tuned!</p>
          )
        }
        <a href="/blog" class="all-posts">View all posts &rarr;</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 6rem 0 2rem;
  }

  .hero-name {
    font-size: clamp(2.5rem, 6vw, 4rem);
    margin: 0 0 0.75rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .hero-name .theme-toggle {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    font: inherit;
    color: var(--muted);
    transition: color 0.2s;
    display: inline-flex;
    align-items: center;
  }

  .hero-name .theme-toggle:hover {
    color: var(--text);
  }

  [data-theme="dark"] .hero-name .theme-toggle .sun {
    display: none;
  }

  .hero-name .theme-toggle .moon {
    display: none;
  }

  [data-theme="dark"] .hero-name .theme-toggle .moon {
    display: block;
  }

  .hero-bio {
    margin: 0 0 2rem;
    font-size: 1.1rem;
    color: var(--muted);
    max-width: 520px;
    line-height: 1.7;
  }

  .hero-chart {
    margin-bottom: 2rem;
    opacity: 0.8;
  }

  .chart-label {
    margin: 0 0 0.5rem;
    font-size: 0.85rem;
    color: var(--muted);
  }

  .hero-social {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .hero-social a {
    color: var(--muted);
    transition: color 0.2s;
    display: flex;
  }

  .hero-social a:hover {
    color: var(--text);
  }

  .tabs {
    display: flex;
    gap: 0;
    margin-bottom: 2.5rem;
    border-bottom: 1px solid var(--border);
  }

  .tab {
    background: none;
    border: none;
    padding: 0.75rem 1.25rem;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--muted);
    cursor: pointer;
    transition: color 0.2s;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    font-family: inherit;
  }

  .tab:hover {
    color: var(--text);
  }

  .tab.active {
    color: var(--text);
    border-bottom-color: var(--text);
  }

  .tab-content {
    display: none;
  }

  .tab-content.active {
    display: block;
  }

  .grid-2 {
    display: grid;
    gap: 2rem;
    grid-template-columns: repeat(2, 1fr);
  }

  .grid-3 {
    display: grid;
    gap: 2rem;
    grid-template-columns: repeat(3, 1fr);
  }

  .project-item h3 {
    margin: 0 0 0.5rem;
    font-size: 1.1rem;
  }

  .project-item p {
    margin: 0 0 1rem;
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.65;
  }

  .project-link {
    font-size: 0.9rem;
    font-weight: 600;
  }

  .skill-item h3 {
    margin: 0 0 0.5rem;
    font-size: 1rem;
  }

  .skill-item p {
    margin: 0;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.65;
  }

  .blog-list {
    display: grid;
    gap: 2rem;
  }

  .blog-item time {
    font-size: 0.85rem;
    color: var(--muted);
  }

  .blog-item h3 {
    margin: 0.3rem 0 0.5rem;
    font-size: 1.1rem;
  }

  .blog-item h3 a {
    color: var(--text);
  }

  .blog-item h3 a:hover {
    opacity: 0.6;
  }

  .blog-item p {
    margin: 0 0 0 0;
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.65;
  }

  .blog-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.6rem;
  }

  .blog-tags .tag {
    font-size: 0.78rem;
    color: var(--muted);
    border: 1px solid var(--border);
    padding: 0.1rem 0.5rem;
    border-radius: var(--radius);
  }

  .all-posts {
    display: inline-block;
    margin-top: 1.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--muted);
    transition: color 0.2s;
  }

  .all-posts:hover {
    color: var(--text);
    opacity: 1;
  }

  .empty {
    color: var(--muted);
  }

  @media (max-width: 640px) {
    .hero {
      padding: 3rem 0 2rem;
    }

    .hero-bio {
      max-width: none;
    }

    .grid-2, .grid-3 {
      grid-template-columns: 1fr;
    }

    .hero-social {
      gap: 0.85rem;
    }

    .tabs {
      gap: 0;
    }

    .tab {
      padding: 0.75rem 0.75rem;
      font-size: 0.85rem;
    }
  }
</style>

<script>
  const tabs = document.querySelectorAll('.tab');
  const contents = {
    projects: document.getElementById('tab-projects'),
    skills: document.getElementById('tab-skills'),
    blog: document.getElementById('tab-blog'),
  };

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      tabs.forEach((t) => t.classList.remove('active'));
      Object.values(contents).forEach((c) => c?.classList.remove('active'));
      tab.classList.add('active');
      const id = tab.dataset.tab;
      if (contents[id]) contents[id].classList.add('active');
    });
  });
</script>
