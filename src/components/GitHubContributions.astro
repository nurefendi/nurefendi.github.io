---
import { Image } from 'astro:assets';
---

<div class="contributions-card card">
  <div class="contrib-header">
    <div>
      <h3>Kontribusi GitHub</h3>
      <p class="contrib-subtitle">Aktivitas dalam 1 tahun terakhir</p>
    </div>
    <a href="https://github.com/nurefendi" target="_blank" rel="noopener" class="contrib-gh-link">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
      @nurefendi
    </a>
  </div>
  <div class="contrib-chart">
    <img src="https://ghchart.rshah.org/nurefendi" alt="Grafik kontribusi GitHub Nurefendi" width="720" height="112" loading="lazy" />
  </div>
  <div class="contrib-footer">
    <span class="contrib-label">Lebih sedikit</span>
    <span class="contrib-color" style="background:#ebedf0"></span>
    <span class="contrib-color" style="background:#9be9a8"></span>
    <span class="contrib-color" style="background:#40c463"></span>
    <span class="contrib-color" style="background:#30a14e"></span>
    <span class="contrib-color" style="background:#216e39"></span>
    <span class="contrib-label">Lebih banyak</span>
  </div>
</div>

<style>
  .contributions-card {
    max-width: 780px;
    margin: 0 auto;
    padding: 2rem;
  }

  .contrib-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .contrib-header h3 {
    margin: 0;
    font-size: 1.2rem;
  }

  .contrib-subtitle {
    margin: 0.25rem 0 0;
    font-size: 0.85rem;
    color: var(--muted);
  }

  .contrib-gh-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--muted);
    text-decoration: none;
    padding: 0.4rem 0.75rem;
    border-radius: 999px;
    background: var(--primary-light);
    border: 1px solid var(--border);
    transition: color 0.2s;
  }

  .contrib-gh-link:hover {
    color: var(--primary);
  }

  .contrib-chart {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .contrib-chart img {
    max-width: none;
    display: block;
  }

  .contrib-footer {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.3rem;
    margin-top: 1rem;
  }

  .contrib-label {
    font-size: 0.75rem;
    color: var(--muted);
  }

  .contrib-color {
    width: 12px;
    height: 12px;
    border-radius: 2px;
    display: inline-block;
  }
</style>
